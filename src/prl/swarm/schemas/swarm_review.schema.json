{
  "$defs": {
    "Carrier": {
      "additionalProperties": false,
      "description": "The execution **carrier-of-record** (ADR-PRL-0009): *what executed* an act, kept\nalongside the logical ``agent_id`` \u2014 never its source. ``provider`` names the carrier\n(``openai`` / ``anthropic`` / ``local`` / ``human``); ``model`` / ``adapter`` are null\nfor a human contributor. The *type* (human vs agent) lives here, not in ``agent_id``.",
      "properties": {
        "adapter": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Adapter"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "provider": {
          "title": "Provider",
          "type": "string"
        }
      },
      "required": [
        "provider"
      ],
      "title": "Carrier",
      "type": "object"
    },
    "Finding": {
      "additionalProperties": false,
      "description": "One review finding (``ReviewReceipt.findings``).",
      "properties": {
        "evidence_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Ref"
        },
        "severity": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Severity"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "summary"
      ],
      "title": "Finding",
      "type": "object"
    },
    "MEF": {
      "additionalProperties": false,
      "description": "Minimal Epistemic Frame (ADR-PRL-0004 Ch2) \u2014 the non-strippable transport\ncontract. The historical fields are required: a record cannot be constructed without a\ncomplete MEF, so \"MEF complete or refuse\" is enforced by the type, not by a\nconvention. ``regime`` is a free string here (its exact taxonomy is ADR-0003 /\nopen question 8.a \u2014 not canonized at this layer).\n\nADR-PRL-0009 adds the **structured contributor attribution**: ``agent_id`` (the stable\nlogical contributor, frame-level \u2014 *who contributes?*) and ``carrier`` (the execution\ncarrier-of-record). Both are **optional** so acts written before 0009 still read with\n``agent_id = None`` (no read-time inference, unknown means unknown). New acts MUST set\n``agent_id`` at the producer. ``agent_id`` is never derived from the carrier.",
      "properties": {
        "agent_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agent Id"
        },
        "carrier": {
          "anyOf": [
            {
              "$ref": "#/$defs/Carrier"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        },
        "confidence": {
          "title": "Confidence",
          "type": "number"
        },
        "contested": {
          "title": "Contested",
          "type": "boolean"
        },
        "producer": {
          "title": "Producer",
          "type": "string"
        },
        "regime": {
          "title": "Regime",
          "type": "string"
        }
      },
      "required": [
        "claim_id",
        "regime",
        "confidence",
        "contested",
        "producer"
      ],
      "title": "MEF",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "One review **lens** with declared visibility \u2014 a declared opinion or\nverification, NEVER objective truth (``review agreement != proof``:\nagreement between reviews is corroboration, not certainty).",
  "properties": {
    "claims_checked": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Claims Checked",
      "type": "array"
    },
    "conflicts_detected": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Conflicts Detected",
      "type": "array"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "evidence_visible": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Evidence Visible",
      "type": "array"
    },
    "findings": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Finding"
      },
      "title": "Findings",
      "type": "array"
    },
    "kind": {
      "const": "review",
      "default": "review",
      "title": "Kind",
      "type": "string"
    },
    "lens": {
      "title": "Lens",
      "type": "string"
    },
    "limitations": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "mef": {
      "anyOf": [
        {
          "$ref": "#/$defs/MEF"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "review_id": {
      "title": "Review Id",
      "type": "string"
    },
    "reviewed_ref": {
      "title": "Reviewed Ref",
      "type": "string"
    },
    "reviewer_agent_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reviewer Agent Id"
    },
    "reviewer_carrier": {
      "anyOf": [
        {
          "$ref": "#/$defs/Carrier"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "schema_version": {
      "default": "swarm.v0.1",
      "title": "Schema Version",
      "type": "string"
    },
    "swarm_run_id": {
      "title": "Swarm Run Id",
      "type": "string"
    },
    "verdict": {
      "anyOf": [
        {
          "enum": [
            "approve",
            "reject",
            "inconclusive"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Verdict"
    }
  },
  "required": [
    "review_id",
    "swarm_run_id",
    "reviewed_ref",
    "lens"
  ],
  "title": "ReviewReceipt",
  "type": "object"
}
