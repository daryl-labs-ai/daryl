AGENT_MESH_DATA_DIR=./data
AGENT_MESH_SERVER_ID=server_main
AGENT_MESH_LOG_LEVEL=INFO

# ── Zhipu AI (GLM) ──────────────────────────────────────────────────────────
# Coding API (glm-code, codegeex)  : https://api.z.ai/api/coding/paas/v4
# General API (glm-4, glm-4-flash) : https://api.z.ai/api/paas/v4
# The backend picks the correct endpoint automatically from the model name.
ZHIPU_API_KEY=your-zhipu-key
ZHIPU_MODEL=glm-4
